# Copy to .env on EC2 (Amazon Linux) before first deploy.
# IP 변경 시 CORS_ALLOWED_ORIGINS, GitHub Secret EC2_HOST 를 함께 갱신하세요.

SPRING_PROFILES_ACTIVE=cloud

# RDS (VPC private — EC2와 같은 VPC)
DB_HOST=database-1.c7qccwq22pg3.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ragdoc
DB_USERNAME=postgres
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=ragdoc-platform

# EC2 퍼블릭 IP 또는 http://<ip> (학습용, IP 변경 시 수정)
CORS_ALLOWED_ORIGINS=http://ec2-43-200-172-207.ap-northeast-2.compute.amazonaws.com

JWT_SECRET=1234567890-1234567890-1234567890-1234567890-1234567890

# S3 (EC2 IAM Role로 인증 — 액세스 키 불필요)
AWS_S3_BUCKET=amzn-s3-gaon-bucket-011122072035-ap-northeast-2-an
AWS_REGION=ap-northeast-2

OPENAI_API_KEY=sk-change-me

# ECR (단일 리포지토리, 태그로 backend/frontend 구분)
BACKEND_IMAGE=011122072035.dkr.ecr.ap-northeast-2.amazonaws.com/edu-was:backend-latest
FRONTEND_IMAGE=011122072035.dkr.ecr.ap-northeast-2.amazonaws.com/edu-was:frontend-latest
