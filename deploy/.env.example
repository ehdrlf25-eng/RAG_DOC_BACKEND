# Copy to .env and fill in values before deployment

# External PostgreSQL server (not containerized)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=ragdoc
DB_USERNAME=postgres
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
# If Redis runs outside ragdoc-net (e.g. auth-redis on host :6379):
# REDIS_HOST=host.docker.internal

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PORT=9092
KAFKA_CONSUMER_GROUP=ragdoc-platform
# If Kafka runs outside ragdoc-net (e.g. auth-kafka on host :9092):
# KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092

JWT_SECRET=change-me-to-a-secure-secret-key-at-least-32-chars
CORS_ALLOWED_ORIGINS=http://localhost:81

# OpenAI (default RAG embedding + chat provider)
OPENAI_API_KEY=sk-change-me
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini
# RAG_EMBEDDING_PROVIDER=openai
# RAG_LLM_PROVIDER=openai
# RAG_EMBEDDING_DIMENSIONS=1536
# RAG_REEMBED_ON_STARTUP=true

# Ollama (optional — set RAG_*_PROVIDER=ollama to switch back)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Host port mapping (default +1 from typical local dev ports 8080 / 80)
BACKEND_HOST_PORT=8081
FRONTEND_PORT=81

# GHCR images (updated by CI/CD)
BACKEND_IMAGE=ghcr.io/ehdrlf25-eng/rag_doc_backend:latest
FRONTEND_IMAGE=ghcr.io/ehdrlf25-eng/rag_doc_frontend:latest
